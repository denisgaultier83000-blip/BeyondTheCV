{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beyondthecv.local/schemas/interview.schema.json",
  "title": "BeyondTheCV - Interview Prep JSON (per language)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "interview_prep",
    "print_pack",
    "warnings"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "primary_country",
        "target_role",
        "company_name",
        "language"
      ],
      "properties": {
        "version": {
          "type": "string"
        },
        "primary_country": {
          "type": "string"
        },
        "target_role": {
          "type": "string"
        },
        "company_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "language": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "interview_prep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sections",
        "questions_to_ask_them",
        "pitches"
      ],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "key",
              "title",
              "qa"
            ],
            "properties": {
              "key": {
                "type": "string",
                "enum": [
                  "cv_based",
                  "company_based",
                  "curiosity_context",
                  "classics"
                ]
              },
              "title": {
                "type": "string"
              },
              "qa": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "id",
                    "question",
                    "answer_points",
                    "tone",
                    "tags"
                  ],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "question": {
                      "type": "string"
                    },
                    "answer_points": {
                      "type": "array",
                      "minItems": 1,
                      "maxItems": 5,
                      "items": {
                        "type": "string"
                      }
                    },
                    "tone": {
                      "type": "string",
                      "enum": [
                        "neutral",
                        "confident",
                        "humble",
                        "direct"
                      ]
                    },
                    "tags": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        },
        "questions_to_ask_them": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "question",
              "why_it_matters"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "question": {
                "type": "string"
              },
              "why_it_matters": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "pitches": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "pitch_30s",
            "pitch_60s",
            "pitch_90s"
          ],
          "properties": {
            "pitch_30s": {
              "type": "string"
            },
            "pitch_60s": {
              "type": "string"
            },
            "pitch_90s": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "print_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommended_order",
        "format_notes"
      ],
      "properties": {
        "recommended_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "format_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}