{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beyondthecv.local/schemas/dossier.schema.json",
  "title": "BeyondTheCV - Personal Career Dossier JSON (per language)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "identity",
    "preferences",
    "summary",
    "experience",
    "education",
    "skills",
    "interests",
    "gaps",
    "documents",
    "notes",
    "warnings"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "language",
        "generated_at_utc",
        "candidate_id",
        "primary_country",
        "secondary_countries",
        "target_roles",
        "intended_use"
      ],
      "properties": {
        "version": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "generated_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "candidate_id": {
          "type": "string"
        },
        "primary_country": {
          "type": "string"
        },
        "secondary_countries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "target_roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "intended_use": {
          "type": "string",
          "enum": [
            "personal_reference_only"
          ]
        }
      },
      "additionalProperties": false
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first_name",
        "last_name",
        "email",
        "phone",
        "location",
        "links"
      ],
      "properties": {
        "first_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "email": {
          "type": [
            "string",
            "null"
          ]
        },
        "phone": {
          "type": [
            "string",
            "null"
          ]
        },
        "location": {
          "type": "object",
          "required": [
            "city",
            "country"
          ],
          "properties": {
            "city": {
              "type": [
                "string",
                "null"
              ]
            },
            "country": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        },
        "links": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "linkedin",
            "portfolio",
            "github",
            "other"
          ],
          "properties": {
            "linkedin": {
              "type": [
                "string",
                "null"
              ]
            },
            "portfolio": {
              "type": [
                "string",
                "null"
              ]
            },
            "github": {
              "type": [
                "string",
                "null"
              ]
            },
            "other": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_language",
        "content_languages",
        "contract_types",
        "tone_preference"
      ],
      "properties": {
        "ui_language": {
          "type": [
            "string",
            "null"
          ]
        },
        "content_languages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contract_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tone_preference": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headline",
        "objective",
        "is_self_taught",
        "self_taught_details",
        "key_strengths"
      ],
      "properties": {
        "headline": {
          "type": [
            "string",
            "null"
          ]
        },
        "objective": {
          "type": [
            "string",
            "null"
          ]
        },
        "is_self_taught": {
          "type": "boolean"
        },
        "self_taught_details": {
          "type": [
            "string",
            "null"
          ]
        },
        "key_strengths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "experience": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "professional",
        "internships"
      ],
      "properties": {
        "professional": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "type",
              "role",
              "company",
              "location",
              "start",
              "end",
              "is_current",
              "missions",
              "achievements",
              "tools"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "role": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "company": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "location": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "start": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "end": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "is_current": {
                "type": "boolean"
              },
              "missions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "achievements": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "internships": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "role",
              "company",
              "location",
              "start",
              "end",
              "missions",
              "deliverables",
              "tools"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "role": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "company": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "location": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "start": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "end": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "missions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "deliverables": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "tools": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "education": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "degrees",
        "certifications"
      ],
      "properties": {
        "degrees": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "degree",
              "institution",
              "location",
              "year",
              "details"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "degree": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "institution": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "location": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "year": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "details": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "certifications": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "issuer",
              "year",
              "credential_id"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "issuer": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "year": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "credential_id": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hard",
        "soft",
        "languages"
      ],
      "properties": {
        "hard": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "level"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "level": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        },
        "soft": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "language",
              "level"
            ],
            "properties": {
              "language": {
                "type": "string"
              },
              "level": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "interests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "duration",
          "reason",
          "activities"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "duration": {
            "type": [
              "string",
              "null"
            ]
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "activities": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "documents": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "photo_provided",
        "photo_notes"
      ],
      "properties": {
        "photo_provided": {
          "type": "boolean"
        },
        "photo_notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_free_notes",
        "system_notes"
      ],
      "properties": {
        "candidate_free_notes": {
          "type": [
            "string",
            "null"
          ]
        },
        "system_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}